def extract_reply_code(response):
    # Ensure input is either str or bytes
    if isinstance(response, bytes):
        response = response.decode('utf-8')
    elif not isinstance(response, str):
        raise ValueError("Invalid input type. Response must be a string or bytes.")

    # Protocol field format information (source of truth)
    protocol_info = [{"field_name": "Reply Code", 
                      "position": "First three digits of the FTP response message", 
                      "explanation": "Used to determine the outcome and category of an FTP server's response to a command. Each of the three digits has specific significance, indicating whether the response is positive, negative, or intermediate and specifying the function or category of the response.", 
                      "value": [110, 120, 125, 150, 200, 202, 211, 212, 213, 214, 215, 220, 221, 225, 226, 227, 230, 250, 257, 331, 332, 350, 421, 425, 426, 450, 451, 452, 500, 501, 502, 503, 504, 530, 532, 550, 551, 552, 553]}]

    # Extract the reply code (status code) according to the position information
    field_info = protocol_info[0]  # Assume single field descriptor is provided
    position_description = field_info["position"]

    if position_description == "First three digits of the FTP response message":
        if len(response) < 3 or not response[:3].isdigit():
            raise ValueError("The status code cannot be located or is not numeric.")
        reply_code = int(response[:3])
    else:
        raise ValueError("Unsupported position description")

    # Validate the reply code against the allowed values
    valid_values = field_info["value"]
    if valid_values and reply_code not in valid_values:
        raise ValueError(f"The value {reply_code} is not in the allowed set.")

    return reply_code
```

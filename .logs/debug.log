    # PrimaryParameter (choose a random decimal integer as a string)
    primary_parameter_value = str(random.randint(1000, 9999))
    primary_parameter = primary_parameter_value.encode('ascii')

    # OptionalWhitespace and OptionalRCharacter
    if random.choice([True, False]):
        optional_whitespace = b'\x20'
        optional_r_character = b'R'
        
        # OptionalSecondaryWhitespace
        optional_secondary_whitespace = b'\x20'
        
        # SecondaryParameter (choose a random decimal integer as a string)

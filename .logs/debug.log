    else:
        optional_whitespace = b''
        optional_r_character = b''
        optional_secondary_whitespace = b''
        secondary_parameter = b''

    # EndOfLine
    end_of_line = b'\x0D\x0A'

    # Build the complete message
    message = (command_code + whitespace1 + 
               primary_parameter +
               optional_whitespace +
               optional_r_character +
               optional_secondary_whitespace +
               secondary_parameter +
               end_of_line)

    return message

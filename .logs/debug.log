def extract_and_validate_ftp_status_code(response_message):
    # Ensure the input is a str for processing
    if isinstance(response_message, bytes):
        response_message = response_message.decode('utf-8')
    elif not isinstance(response_message, str):
        raise ValueError("Response message must be a string or bytes")

    # Extract the first three characters which represent the reply code
    if len(response_message) >= 3:
        code_str = response_message[:3]
    else:
        raise ValueError("Response message is too short to contain a valid status code")

    # Validate that the extracted code is numeric
    if not code_str.isdigit():
        raise ValueError("Extracted status code is not numeric")

    # Convert the string representation of the code to an integer
    status_code = int(code_str)

    # Define valid values
    valid_values = [110, 120, 125, 150, 200, 202, 211, 212, 213, 214, 215, 
                    220, 221, 225, 226, 227, 230, 250, 257, 331, 332, 350, 
                    421, 425, 426, 450, 451, 452, 500, 501, 502, 503, 504, 
                    530, 532, 550, 551, 552, 553]

    # Validate the extracted status code against the list of valid values
    if status_code not in valid_values:
        raise ValueError("Extracted status code is not in the valid values list")

    return status_code
```

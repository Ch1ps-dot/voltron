<?xml version='1.0' encoding='UTF-8' standalone='yes'?>
<ir>
  <message name="110">
    <!-- FTP 110 reply: Restart marker reply; indicates a marker reply to the user, as per RFC 959 -->
    
    <field name="ReplyCode" type="constant" length="3B" value="110"/>
    <!-- 3-digit FTP reply code for "Restart marker reply" -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Single space character separating reply code from text -->

    <field name="MarkerText" type="variable" length="undefined" value="Printable ASCII except CR, LF"/>
    <!-- Textual marker string describing the restart marker or status; content varies per server implementation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of reply line -->
</message>
  <message name="120">
    <!-- FTP Reply 120: Service ready in nnn minutes. This is a positive preliminary reply indicating that the service is not ready yet, but will be in a specified amount of time. -->

    <field name="ReplyCode" type="constant" length="3B" value="120"/>
    <!-- 3-digit FTP reply code, always '120' for this message, indicating "Service ready in nnn minutes." -->

    <field name="Whitespace1" type="constant" length="1B" value="0x20"/>
    <!-- Single space character separating the reply code from the message text -->

    <field name="MessageText" type="variable" length="undefined" value="ASCII, typically: 'Service ready in nnn minutes.'"/>
    <!-- Human-readable message. Usually "Service ready in nnn minutes." where 'nnn' is a 3-digit number representing minutes. The length is variable but restricted to visible ASCII, excluding CR, LF. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed (CRLF) indicating the end of the reply line -->
</message>
  <message name="125">
    <!-- FTP server reply 125: 'Data connection already open; transfer starting.' Indicates that a data connection is open and the file transfer will start immediately. -->

    <field name="ReplyCode" type="constant" length="3B" value="125"/>
    <!-- The 3-digit FTP reply code '125' indicating a positive preliminary reply for data transfer. -->

    <field name="Whitespace1" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from textual explanation. -->

    <field name="ReplyText" type="constant" length="39B" value="Data connection already open; transfer starting."/>
    <!-- Standard explanatory text for the 125 reply. Some servers may include slight variations, but the RFC-defined phrase is shown here. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters indicating end of the reply line. -->
</message>
  <message name="150">
    <!-- FTP reply message "150" indicating that the server is about to open a data connection and start transferring data -->

    <field name="ReplyCode" type="constant" length="3B" value="150"/>
    <!-- 3-digit status code identifying the FTP reply type as 'File status okay; about to open data connection' -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code and the human-readable message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text elaborating the reply, content may vary (e.g., 'Opening BINARY mode data connection') -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed sequence marking the end of the reply message -->
</message>
  <message name="200">
    <!-- FTP positive completion reply: indicates that the requested command has been executed successfully. Commonly used message code after command execution -->

    <field name="ReplyCode" type="constant" length="3B" value="200"/>
    <!-- Constant code '200' indicating a successful command completion in FTP -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the reply text as per FTP specification -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text providing detail about the successful completion. May vary by server and command; always excludes carriage return and line feed characters -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed marking the end of the reply line in FTP reply messages -->
</message>
  <message name="202">
    <!-- FTP server reply code 202: Command not implemented, superfluous at this site. Indicates the command was understood but is not needed or supported here. -->

    <field name="ReplyCode" type="constant" length="3B" value="202"/>
    <!-- Three-digit reply code indicating the nature of the FTP server response; here, '202' signifies "Command not implemented, superfluous at this site." -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the human-readable message text -->

    <field name="ReplyText" type="constant" length="41B" value="Command not implemented, superfluous at this site."/>
    <!-- Human-readable explanation associated with this reply code; exact message per RFC 959, section 4.2, for reply 202. Length is 41 ASCII characters. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed (CRLF) marking the end of the reply line per FTP protocol. -->
</message>
  <message name="211">
    <!-- FTP reply code 211: System status, or system help reply. Used to indicate a system status or return help information to the client. -->

    <field name="ReplyCode" type="constant" length="3B" value="211"/>
    <!-- 3-digit numeric FTP reply code indicating a system status or help reply -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space separator following the reply code per FTP response syntax -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII printable characters, excluding CR and LF"/>
    <!-- Human-readable status or help information returned by the server; content varies depending on server implementation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters marking end of the server reply line, as required by FTP specification -->
</message>
  <message name="212">
    <!-- FTP reply 212: Status response indicating "Directory status" per RFC 959; server sends this message to provide directory status information -->

    <field name="ReplyCode" type="constant" length="3B" value="212"/>
    <!-- Three-digit FTP reply code for "Directory status" -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from the textual message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text describing the directory status; content varies per server implementation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed marking the end of the reply line -->
</message>
  <message name="213">
    <!-- FTP server reply code 213: Used to indicate a file status response, such as the size of a file in response to a SIZE command -->

    <field name="ReplyCode" type="constant" length="3B" value="213"/>
    <!-- The FTP response code 213 (ASCII '213'), indicating a file status, often the result of a SIZE command -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code and status information -->

    <field name="StatusInfo" type="variable" length="undefined" value="ASCII digits (0-9)"/>
    <!-- Information associated with the code 213, most commonly the size of the requested file in decimal ASCII digits -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters (CRLF), marking the end of the reply line as per FTP specification -->
</message>
  <message name="214">
    <!-- FTP 214 Reply: Used by server to provide a textual help message in response to the HELP command -->

    <field name="ReplyCode" type="constant" length="3B" value="214"/>
    <!-- 3-digit reply code indicating a help message (214) per FTP specification -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character (ASCII 0x20) separating reply code from text -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable help or information text provided by the FTP server; contents depend on HELP argument and server implementation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed (CRLF, ASCII 0x0D0A) marking the end of the reply line -->

</message>
  <message name="215">
    <!-- FTP server reply code 215: System Type. Sent in response to the SYST command, indicates server operating system type. -->

    <field name="ReplyCode" type="constant" length="3B" value="215"/>
    <!-- Reply code indicating the server's system type response. Always the value "215". -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space separator between reply code and system type string. -->

    <field name="SystemType" type="variable" length="undefined" value="ASCII printable characters"/>
    <!-- Textual description of the server's operating system type, such as "UNIX Type: L8". Length and content may vary in accordance with RFC959, excluding CR and LF. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed sequence indicating the end of the reply line. -->
</message>
  <message name="220">
    <!-- FTP server reply indicating that the service is ready for a new user (sent upon initial connection) -->

    <field name="ReplyCode" type="constant" length="3B" value="220"/>
    <!-- Three-digit FTP reply code signaling "Service ready for new user" -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code and message text -->

    <field name="MessageText" type="variable" length="undefined" value="ASCII printable (0x20-0x7E), optionally empty"/>
    <!-- Human-readable text explaining the welcome or service readiness; commonly a greeting or host identification -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed marking the end of the server reply -->
</message>
  <message name="221">
    <!-- FTP reply code 221: Service closing control connection; sent by server to indicate successful termination of the session -->

    <field name="ReplyCode" type="constant" length="3B" value="221"/>
    <!-- Three-digit FTP reply code indicating that the server is closing the control connection -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from the textual explanation -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII characters excluding CR, LF"/>
    <!-- Human-readable text message explaining service closure; content may vary, commonly "Service closing control connection" -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the response line -->
</message>
  <message name="225">
    <!-- FTP server response message 225: "Data connection open; no transfer in progress". 
         Used to indicate that the data connection is open but currently idle (no data transfer taking place). -->

    <field name="ReplyCode" type="constant" length="3B" value="225"/>
    <!-- 3-digit FTP reply code indicating the specific server response (here: data connection open, no transfer in progress) -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character (ASCII 0x20) separating reply code and message text -->

    <field name="ReplyText" type="constant" length="34B" value="Data connection open; no transfer in progress"/>
    <!-- Reply text providing human-readable explanation of the server state; this text is defined by the FTP protocol RFC for reply code 225 -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR, 0x0D) and Line Feed (LF, 0x0A) characters indicating end of the FTP response line -->
</message>
  <message name="226">
    <!-- FTP reply message 226: Indicates that a data connection was closed and the requested file action was successfully completed -->

    <field name="ReplyCode" type="constant" length="3B" value="226"/>
    <!-- Fixed 3-digit reply code for "Closing data connection", per FTP RFC 959 -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space separator between the reply code and the textual reply message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text string providing additional status information; optional and may vary per FTP server -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR) and Line Feed (LF) characters indicating end of the reply line -->
</message>
  <message name="227">
    <!-- FTP server reply to indicate entering passive mode, providing the host and port for data connection. -->

    <field name="ReplyCode" type="constant" length="3B" value="227"/>
    <!-- 3-digit reply code for "Entering Passive Mode". Indicates the nature of the server response. -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code and message text. -->

    <field name="TextPrefix" type="constant" length="26B" value="Entering Passive Mode ("/>
    <!-- Message string indicating the start of passive mode details. Fixed text per RFC 959. -->

    <field name="HostIpPart1" type="variable" length="undefined" value="ASCII digits (0-255)"/>
    <!-- First octet of the server's IP address, encoded as ASCII decimal digits. -->

    <field name="Separator1" type="constant" length="1B" value="0x2C"/>
    <!-- Comma character ',' separating IP address components. -->

    <field name="HostIpPart2" type="variable" length="undefined" value="ASCII digits (0-255)"/>
    <!-- Second octet of the server's IP address, encoded as ASCII decimal digits. -->

    <field name="Separator2" type="constant" length="1B" value="0x2C"/>
    <!-- Comma character ',' separating IP address components. -->

    <field name="HostIpPart3" type="variable" length="undefined" value="ASCII digits (0-255)"/>
    <!-- Third octet of the server's IP address, encoded as ASCII decimal digits. -->

    <field name="Separator3" type="constant" length="1B" value="0x2C"/>
    <!-- Comma character ',' separating IP address components. -->

    <field name="HostIpPart4" type="variable" length="undefined" value="ASCII digits (0-255)"/>
    <!-- Fourth octet of the server's IP address, encoded as ASCII decimal digits. -->

    <field name="Separator4" type="constant" length="1B" value="0x2C"/>
    <!-- Comma character ',' separating IP address and port numbers. -->

    <field name="PortHighByte" type="variable" length="undefined" value="ASCII digits (0-255)"/>
    <!-- High byte (most significant 8 bits) of the port number, encoded as ASCII decimal digits. -->

    <field name="Separator5" type="constant" length="1B" value="0x2C"/>
    <!-- Comma character ',' separating the two port bytes. -->

    <field name="PortLowByte" type="variable" length="undefined" value="ASCII digits (0-255)"/>
    <!-- Low byte (least significant 8 bits) of the port number, encoded as ASCII decimal digits. -->

    <field name="TextSuffix" type="constant" length="1B" value="0x29"/>
    <!-- Closing parenthesis ')' ending passive mode details. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed (CRLF) indicating end of the reply message. -->
</message>
  <message name="230">
    <!-- FTP server reply code 230: Indicates successful login of the user ("User logged in, proceed") -->

    <field name="ReplyCode" type="constant" length="3B" value="230"/>
    <!-- Three-digit FTP reply code indicating user is logged in and may proceed with commands -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character required between reply code and the reply text per FTP reply formatting -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable explanation, typically "User logged in, proceed"; actual content may vary but must not contain Carriage Return or Line Feed characters -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed sequence marking the end of the FTP reply message -->
</message>
  <message name="250">
    <!-- FTP server positive completion reply (250) indicates requested operation completed successfully, e.g., directory change succeeded -->

    <field name="ReplyCode" type="constant" length="3B" value="250"/>
    <!-- 3-digit FTP reply code "250" indicating the positive completion status -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the rest of the message text -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII, printable chars, excluding CR, LF"/>
    <!-- Human-readable reply message text describing success (e.g., "Directory successfully changed") -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- CRLF sequence marking the end of the reply line -->
</message>
  <message name="257">
    <!-- FTP server reply to PWD/XCWD commands: returns current directory pathname in a specified format -->

    <field name="ReplyCode" type="constant" length="3B" value="257"/>
    <!-- 3-digit FTP reply code indicating "PATHNAME created" or "current directory returned" -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from the text response -->

    <field name="QuotedPathname" type="variable" length="undefined" value="ASCII, enclosed in double quotes, excluding CR, LF, and embedded quotes"/>
    <!-- The current directory pathname as returned by the server, always enclosed in double quotes. Content is ASCII and may vary according to server implementation. -->

    <field name="Text" type="variable" length="undefined" value="ASCII, excluding CR, LF"/>
    <!-- Optional explanatory text following the pathname, such as descriptive comments. May be empty. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed marking the end of the reply line -->
</message>
  <message name="331">
    <!-- FTP server reply code 331: User name okay, need password. Indicates that the USER command was accepted and the server now expects a PASS command with the user's password. -->

    <field name="ReplyCode" type="constant" length="3B" value="331"/>
    <!-- Numeric FTP reply code indicating 'User name okay, need password' -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from the textual explanation -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable textual explanation sent by the server; typically 'User name okay, need password.' but actual wording may vary -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters denoting the end of the reply message -->
</message>
  <message name="332">
    <!-- FTP reply 332: "Need account for login" - sent by the server in response to a login attempt indicating that further account information is required -->

    <field name="ReplyCode" type="constant" length="3B" value="332"/>
    <!-- The three-digit FTP reply code '332' indicating 'Need account for login' -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the text reply message (ASCII space) -->

    <field name="ReplyText" type="constant" length="24B" value="Need account for login"/>
    <!-- Standard textual explanation corresponding to reply code 332; typically 'Need account for login' as defined by RFC 959 -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR, 0x0D) and Line Feed (LF, 0x0A) indicating the end of the reply line -->
</message>
  <message name="350">
    <!-- FTP reply 350: Indicates that the requested file action is pending further information; e.g., 350 Requested file action pending further information. Typically used as a positive intermediate reply -->

    <field name="ReplyCode" type="constant" length="3B" value="350"/>
    <!-- The FTP three-digit reply code for 'Requested file action pending further information' -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from the textual message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text message describing the intermediate reply; content varies depending on context, but must not contain carriage return or line feed -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed sequence marking the end of the reply line -->
</message>
  <message name="421">
    <!-- FTP reply 421: Service not available, closing control connection.
         Sent by server to indicate it is shutting down or cannot open more connections. -->

    <field name="ReplyCode" type="constant" length="3B" value="421"/>
    <!-- Three-digit reply code indicating "Service not available, closing control connection". -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the text explanation. -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text explaining the reason, such as "Service not available, closing control connection". Actual text may vary by server implementation. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the server reply line. -->
</message>
  <message name="425">
    <!-- FTP reply 425: Indicates that the data connection cannot be opened ("Can't open data connection.") -->

    <field name="ReplyCode" type="constant" length="3B" value="425"/>
    <!-- The FTP three-digit reply code for 'Can't open data connection.' -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the textual explanation -->

    <field name="ReplyText" type="constant" length="28B" value="Can't open data connection."/>
    <!-- Human-readable explanation as defined in RFC 959; text is fixed for code 425 -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the FTP reply message -->
</message>
  <message name="426">
    <!-- FTP reply 426: Indicates that the connection was closed; transferring file aborted -->

    <field name="ReplyCode" type="constant" length="3B" value="426"/>
    <!-- 3-digit FTP reply code uniquely identifying the reason for the response -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the reply text -->

    <field name="ReplyText" type="constant" length="39B" value="Connection closed; transfer aborted."/>
    <!-- Standard message text explanatory of the reply code; actual text used in RFC and most servers. Length may vary depending on server implementation. If implementation differs, this field may be variable and the length should be marked as 'undefined'. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed pair marking the end of the FTP server reply line -->

</message>
  <message name="450">
    <!-- FTP reply code 450: Requested file action not taken; file unavailable (e.g., file busy) -->

    <field name="ReplyCode" type="constant" length="3B" value="450"/>
    <!-- 3-digit FTP reply code indicating the response type: 450 means requested action not taken, file unavailable -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code and the textual message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text message providing details about why the requested action was not taken; content may vary by implementation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed sequence marking the end of the reply message -->
</message>
  <message name="451">
    <!-- FTP reply message: 451 Requested action aborted. Local error in processing.
         Indicates a transient error from the server; the command could not be processed due to a local issue, but may succeed if retried. -->

    <field name="ReplyCode" type="constant" length="3B" value="451"/>
    <!-- 3-digit FTP reply code indicating 'Requested action aborted. Local error in processing.' -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code and explanatory message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable explanation for the error; content may vary by implementation.
         Usually starts with 'Requested action aborted. Local error in processing.' but may include additional server info. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed marking the end of the reply message -->
</message>
  <message name="452">
    <!-- FTP Reply Code 452: Response indicating that the requested file action was not taken due to insufficient system storage -->

    <field name="ReplyCode" type="constant" length="3B" value="452"/>
    <!-- Three-digit FTP reply code "452" indicating the specific error condition -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the reply code from the reply text; ASCII space (0x20) as per standard FTP response formatting -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable explanation of the error, e.g., "Requested action not taken. Insufficient storage space in system." Content may vary per server implementation, typically ASCII text, terminated by end-of-line -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed sequence (CRLF) marking the end of the reply message, as specified by FTP RFC -->
</message>
  <message name="500">
    <!-- FTP reply message indicating a syntax error or unrecognized command; sent from server to client -->

    <field name="ReplyCode" type="constant" length="3B" value="500"/>
    <!-- 3-digit reply code '500' indicating 'Syntax error, command unrecognized' as per RFC 959 -->

    <field name="Separator" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from optional message text -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable explanation or descriptive text for the error; may be absent or empty. Content is implementation-defined but ASCII only. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters indicating end of the reply message -->
</message>
  <message name="501">
    <!-- FTP reply code 501: Syntax error in parameters or arguments. Sent by the server in response to a command with incorrect or malformed parameters. -->

    <field name="ReplyCode" type="constant" length="3B" value="501"/>
    <!-- Three-digit reply code indicating syntax error in command arguments -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from the reply text message -->

    <field name="ReplyText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Human-readable text message describing the syntax error. Content may vary per server implementation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the reply message -->
</message>
  <message name="502">
    <!-- FTP 502 Reply: Indicates that the command is not implemented. Sent from server to client in response to an unrecognized or unsupported command. -->

    <field name="ReplyCode" type="constant" length="3B" value="502"/>
    <!-- 3-digit reply code "502" indicating 'Command not implemented'. Always present at the start of the reply line. -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Single space character separating the reply code and the textual reply message. -->


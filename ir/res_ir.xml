    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code from message text -->

    <field name="TextIntro" type="constant" length="19B" value="Entering Passive Mode"/>
    <!-- Text intro describing the passive mode reply before the address and port -->

    <field name="Whitespace2" type="constant" length="1B" value="0x20"/>
    <!-- Space character following 'Entering Passive Mode' before the parenthesis -->

    <field name="LeftParen" type="constant" length="1B" value="0x28"/>
    <!-- Open parenthesis '(' before the address and port -->

    <field name="IPAddress" type="variable" length="undefined" value="0-255"/>
    <!-- Four comma-separated decimal numbers each representing 8 bits of the server's IP address -->

    <field name="CommaSeparator1" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separating the first IP address segment from the second -->

    <field name="CommaSeparator2" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separating the second IP address segment from the third -->

    <field name="CommaSeparator3" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separating the third IP address segment from the fourth -->

    <field name="CommaSeparator4" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separating the fourth IP address segment from the first port byte -->

    <field name="PortHigh" type="variable" length="undefined" value="0-255"/>
    <!-- Two comma-separated 8-bit integers representing the high-order byte of the TCP port -->

    <field name="CommaSeparator5" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separating the high-order port byte from the low-order port byte -->

    <field name="PortLow" type="variable" length="undefined" value="0-255"/>
    <!-- The low-order byte of the TCP port used for passive data connection -->

    <field name="RightParen" type="constant" length="1B" value="0x29"/>
    <!-- Close parenthesis ')' indicating the end of the address and port -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the reply message -->
</message>

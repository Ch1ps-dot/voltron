<ir>
  <message name="110">
    <!-- The message represents an FTP restart marker reply, consisting of the reply code, constant text, and numeric user and server stream markers. -->

    <field name="ReplyCode" type="constant" length="3B" value="110"/>
    <!-- The field denotes a constant 3-digit reply code for a restart marker reply in FTP. -->

    <field name="Whitespace1" type="constant" length="1B" value="0x20"/>
    <!-- Space character to separate the reply code and the text "MARK". -->

    <field name="Text" type="constant" length="4B" value="MARK"/>
    <!-- Fixed text "MARK" indicating the beginning of the marker reply.
         Note: Corrected length from 5B to 4B to match the actual length of the text. -->

    <field name="Whitespace2" type="constant" length="1B" value="0x20"/>
    <!-- Space character following the "MARK" keyword. -->

    <field name="UserStreamMarker" type="variable" length="undefined" value="numeric"/>
    <!-- Numeric value representing user-process data stream marker. Length is undefined as it depends on the numeric range. -->

    <field name="Whitespace3" type="constant" length="1B" value="0x20"/>
    <!-- Space character between user stream marker and equal sign. -->

    <field name="EqualsSign" type="constant" length="1B" value="0x3D"/>
    <!-- Equal sign used to separate user and server markers. -->

    <field name="Whitespace4" type="constant" length="1B" value="0x20"/>
    <!-- Space character between equal sign and server stream marker. -->

    <field name="ServerStreamMarker" type="variable" length="undefined" value="numeric"/>
    <!-- Numeric value for the server's equivalent marker, specified by the server. Length is undefined as it depends on the numeric range. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the message line. -->
</message>

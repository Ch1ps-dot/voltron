<?xml version='1.0' encoding='UTF-8' standalone='yes'?>
<ir>
  <message name="USER">
    <!-- Command to initiate a login by specifying the username for FTP access -->
    
    <field name="CommandCode" type="constant" length="4B" value="USER"/>
    <!-- Command code to specify the user's name for login; fixed length of four characters -->
    
    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->
    
    <field name="Username" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Username to be used for user authentication on the FTP server; variable length string; must be ASCII and cannot contain CR or LF characters -->
    
    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="PASS">
    <!-- Message used to send a user's password to authenticate with the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="PASS"/>
    <!-- Command Code indicating this is a password authentication message -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and the password argument -->

    <field name="Password" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- User's password for authentication; must exclude Carriage Return (CR) and Line Feed (LF) -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command -->
</message>
  <message name="ACCT">
    <!-- Command to specify account information for access control in FTP -->

    <field name="CommandCode" type="constant" length="4B" value="ACCT"/>
    <!-- Command code indicating an account info request to the FTP server -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the command code and the account information -->

    <field name="AccountInformation" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- The account information string, which must not include carriage return or line feed characters -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command message -->
</message>
  <message name="CWD">
    <!-- Command to change the working directory on the FTP server -->

    <field name="CommandCode" type="constant" length="3B" value="CWD"/>
    <!-- Command code indicating a change of working directory -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character (ASCII 0x20) separating command code and argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Directory path to set as the current working directory on the server -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (0x0D) and Line Feed (0x0A) indicating end of the command -->
</message>
  <message name="CDUP">
    <!-- Command to change to the parent directory on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="CDUP"/>
    <!-- Command code indicating change to the parent directory -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command -->
</message>
  <message name="SMNT">
    <!-- Command to structure the mount on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="SMNT"/>
    <!-- Command code indicating the SMNT (Structure Mount) operation -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the command code from the pathname,
         represented as a single byte (0x20 is ASCII for space) -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Pathname specifies the directory to be mounted on the server.
         Length is undefined as it depends on user input.
         Must exclude carriage return (CR) and line feed (LF) characters. -->
    
    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR) and Line Feed (LF) sequence indicating the end of the command.
         This is a standard line ending for FTP commands. -->
</message>
  <message name="QUIT">
    <!-- Command to terminate the user's FTP session -->

    <field name="CommandCode" type="constant" length="4B" value="QUIT"/>
    <!-- Constant command code indicating the termination of the FTP session -->

    <field name="EndOfLine" type="constant" length="2B" value="\r\n"/>
    <!-- Carriage Return and Line Feed marking the end of the command -->
</message>
  <message name="REIN">
    <!-- Command to reinitialize the FTP session state without disconnecting. Used to reset and prepare for new commands. -->

    <field name="CommandCode" type="constant" length="4B" value="REIN"/>
    <!-- Command code indicating a request to reinitialize the connection state -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command -->
</message>
  <message name="PORT">
    <!-- Command to specify the data port for FTP data connection -->

    <field name="CommandCode" type="constant" length="4B" value="PORT"/>
    <!-- Command code indicating data port specification for data connection -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and arguments -->

    <field name="HostNumber" type="variable" length="undefined" value="four decimal integers 0-255"/>
    <!-- Internet host address composed of four decimal fields, separated by commas -->

    <field name="CommaDelimiter1" type="constant" length="1B" value="0x2C"/>
    <!-- Comma delimiter separating the first and second host number fields -->

    <field name="CommaDelimiter2" type="constant" length="1B" value="0x2C"/>
    <!-- Comma delimiter separating the second and third host number fields -->

    <field name="CommaDelimiter3" type="constant" length="1B" value="0x2C"/>
    <!-- Comma delimiter separating the third and fourth host number fields -->

    <field name="PortNumber" type="variable" length="undefined" value="two decimal integers 0-255"/>
    <!-- TCP/IP port address composed of two decimal fields, separated by commas -->

    <field name="CommaDelimiter4" type="constant" length="1B" value="0x2C"/>
    <!-- Comma delimiter separating the host number and first port number fields -->

    <field name="CommaDelimiter5" type="constant" length="1B" value="0x2C"/>
    <!-- Comma delimiter separating the first and second port number fields -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed marking the end of the command -->
</message>
  <message name="PASV">
    <!-- Command to request the server to enter passive mode, where it listens on a data port -->

    <field name="CommandCode" type="constant" length="4B" value="PASV"/>
    <!-- Command code indicating the server should enter passive mode -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the PASV command -->
</message>
  <message name="TYPE">
    <!-- Command to specify the data representation type for file transfer in FTP -->

    <field name="CommandCode" type="constant" length="4B" value="TYPE"/>
    <!-- Command code indicating the representation type of data to be set -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and type argument -->

    <field name="TypeCode" type="variable" length="1B" value="[A, E, I, L]"/>
    <!-- Representation type: A for ASCII, E for EBCDIC, I for Image, L for Local byte -->

    <field name="FormatOrByteSize" type="variable" length="undefined" value="&lt;ASCII, EBCDIC format: [N, T, C] when TypeCode is A or E; Decimal Integer for Local byte size when TypeCode is L&gt;"/>
    <!-- Optional second parameter:
         - For ASCII/EBCDIC, specifies format code (N, T, C).
         - For Local byte representation, specifies the byte size as a Decimal Integer.
         Note: Dependencies exist based on TypeCode (A, E, L) -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="STRU">
    <!-- FTP STRU command - Specifies file structure for data transfer -->

    <field name="CommandCode" type="constant" length="4B" value="STRU"/>
    <!-- Fixed command code for the STRU command -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->

    <field name="StructureCode" type="variable" length="1B" value="[F,R,P]"/>
    <!-- Determines the file structure for data transfer:
         F - File structure (no special structure),
         R - Record structure,
         P - Page structure -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return followed by Line Feed signaling the end of the command -->
</message>
  <message name="MODE">
    <!-- Command to set the transfer mode for FTP data connections -->

    <field name="CommandCode" type="constant" length="4B" value="MODE"/>
    <!-- Command code specifying the transfer mode change request -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->

    <field name="ModeCode" type="variable" length="1B" value="restricted to options: S, B, C"/>
    <!-- Mode code specifying the transfer mode: S for Stream, B for Block, C for Compressed mode as per RFC 959 -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="RETR">
    <!-- Command to retrieve a file from the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="RETR"/>
    <!-- Command code indicating a request to retrieve a file from the server -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Pathname of the file to be retrieved; provided by the user and should not include control characters like CR, LF -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="STOR">
    <!-- Command to store a file on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="STOR"/>
    <!-- Command code indicating a request to store a file -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character (ASCII space) separating the command code and the argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII without CR or LF"/>
    <!-- Pathname of the file to be stored on the server; Length determined by command structure, typically up to the end of the line -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the FTP command line -->
</message>
  <message name="STOU">
    <!-- The STOU command is used to store a file with a unique name generated by the FTP server -->
    
    <field name="CommandCode" type="constant" length="4B" value="STOU"/>
    <!-- Command code for a request to store a file uniquely. -->
    
    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Single space character separating the command from the argument. -->

    <field name="UniqueFilename" type="variable" length="undefined" value="ASCII text"/>
    <!-- The filename to be generated uniquely by the server, provided in the STOU response. 
         The server will determine the unique filename and return it. This field's length 
         is undefined since it depends on the server's response, and content must be ASCII text. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command. -->
</message>
  <message name="APPE">
    <!-- Command to append data to a file on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="APPE"/>
    <!-- Command code indicating an append operation on a file -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Pathname of the file to which data is to be appended on the server. Expected to be a textual path in ASCII format, excluding carriage return and line feed characters. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->

    <!-- Ensure compliance with protocol descriptions using CRLF to denote the end of FTP command messages. -->
</message>
  <message name="ALLO">
    <!-- Command to allocate sufficient space for a file on the server -->

    <field name="CommandCode" type="constant" length="4B" value="ALLO"/>
    <!-- Command code for space allocation request -->

    <field name="Whitespace1" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and primary parameter -->

    <field name="PrimaryParameter" type="variable" length="undefined" value="decimal integer"/>
    <!-- The primary allocation size in bytes, determining minimum space to allocate -->

    <field name="OptionalWhitespace" type="variable" length="1B" value="0x20"/>
    <!-- Optional space character between primary parameter and 'R', if present -->

    <field name="OptionalRCharacter" type="constant" length="1B" value="R"/>
    <!-- Optional 'R' character indicating a secondary parameter follows -->

    <field name="OptionalSecondaryWhitespace" type="variable" length="1B" value="0x20"/>
    <!-- Optional space character between 'R' and secondary allocation size, if present -->

    <field name="SecondaryParameter" type="variable" length="undefined" value="decimal integer"/>
    <!-- Optional secondary allocation size in bytes, used if 'R' character is present -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="REST">
    <!-- FTP REST command to restart an interrupted file transfer from a specific byte offset -->

    <field name="CommandCode" type="constant" length="4B" value="REST"/>
    <!-- Command code indicating a request to restart a file transfer from a specific byte offset -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the command code and the byte offset argument -->

    <field name="Offset" type="variable" length="undefined" value="ASCII digits (48-57)"/>
    <!-- Offset for the restart point as a sequence of ASCII digits indicating the byte position to continue from -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command -->
</message>
  <message name="RNFR">
    <!-- Command to specify the old pathname of the file for renaming on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="RNFR"/>
    <!-- Command code indicating the request to specify the file to be renamed -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and the pathname argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Pathname of the file to be identified for renaming, variable length and consisting of ASCII characters except CR and LF -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="RNTO">
    <!-- Command to rename a file on the FTP server, specifying the new pathname for the file -->
    
    <field name="CommandCode" type="constant" length="4B" value="RNTO"/>
    <!-- Command code indicating rename to a new pathname -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- New pathname for the file to rename on the server; dynamic length based on pathname submitted by user -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command -->
</message>
  <message name="ABOR">
    <!-- Command to abort a file transfer in progress on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="ABOR"/>
    <!-- Command code that instructs the FTP server to abort an ongoing data transfer operation -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (0x0D) and Line Feed (0x0A) indicating the end of the ABOR command -->
</message>
  <message name="DELE">
    <!-- Command to delete a file on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="DELE"/>
    <!-- The FTP command code that indicates a request to delete a file -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- A single space character separating the command code and the pathname -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- The pathname of the file to be deleted from the server. It is a variable length field consisting of ASCII characters, excluding CR and LF -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR) and Line Feed (LF) characters indicating the end of the command -->
</message>
  <message name="RMD">
    <!-- Message to remove a directory on the FTP server -->

    <field name="CommandCode" type="constant" length="3B" value="RMD"/>
    <!-- Command code "RMD" indicating the removal of a directory -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character (ASCII 0x20) separating the command code and argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Path of the directory to be removed; it can contain any ASCII character except CR (0x0D) and LF (0x0A) -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR, 0x0D) and Line Feed (LF, 0x0A) indicating the end of the command -->
</message>
  <message name="MKD">
    <!-- Command to create a new directory on the FTP server -->

    <field name="CommandCode" type="constant" length="3B" value="MKD"/>
    <!-- Command code indicating the creation of a new directory -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character (ASCII) separating the command code and the argument -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Directory path to create on the server; must be a valid pathname as per the server's filesystem -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed (CRLF) indicating the end of the command -->
</message>
  <message name="PWD">
    <!-- Command to request the current working directory on the FTP server -->

    <field name="CommandCode" type="constant" length="3B" value="PWD"/>
    <!-- Command code indicating a PWD (Print Working Directory) request -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command, per FTP protocol -->
</message>
  <message name="LIST">
    <!-- LIST command in FTP to list files in the current directory or the specified pathname -->

    <field name="CommandCode" type="constant" length="4B" value="LIST"/>
    <!-- Command code indicating a request to list directory contents -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument. Can be optional if no pathname is provided -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Optional pathname specifying the directory to list files from; if omitted, lists current directory -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating the end of the command -->
</message>
  <message name="NLST">
    <!-- Command to list names of files in the specified directory on the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="NLST"/>
    <!-- Command code indicating a request to list file names -->

    <!-- The whitespace between the command and the pathname argument is necessary only if a pathname is provided -->
    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument, if argument is provided -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Directory path for which file names are requested. Optional field: if not provided, the server uses the current directory -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="SITE">
    <!-- Command for sending site-specific commands to the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="SITE"/>
    <!-- Command code for indicating the SITE command, which allows sending specific instructions to the server -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument -->

    <field name="SiteParameter" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Site-specific parameter or command to execute; content varies based on server capabilities -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="SYST">
    <!-- Command to request the system type from the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="SYST"/>
    <!-- The SYST command is used to request the system type of the FTP server. 
         This field is a constant representing the command code. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return (CR) and Line Feed (LF) indicating the end of the SYST command.
         These are standard end-of-line characters for FTP commands. -->

</message>
  <message name="STAT">
    <!-- STAT command requests status information from the FTP server -->

    <field name="CommandCode" type="constant" length="4B" value="STAT"/>
    <!-- Command code for the status request. This field is fixed and cannot be altered. -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating the command code from the argument. This field is optional and required only if a Pathname argument is provided. -->

    <field name="Pathname" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Optional directory path to request status information for a specific directory. If this field is omitted, the status information for the server is requested by default. The pathname can contain any ASCII character except Carriage Return (CR) and Line Feed (LF). -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters marking the end of the command. These characters are critical for delimiting the end of FTP commands. -->
</message>
  <message name="HELP">
    <!-- A command requesting help or information about FTP commands from the server -->

    <field name="CommandCode" type="constant" length="4B" value="HELP"/>
    <!-- Command code indicating a request for help or information on FTP commands -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating command code and argument, optional if no argument is provided -->

    <field name="Argument" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Optional argument specifying which command or topic help is requested for. If absent, help for all commands is provided. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
  <message name="NOOP">
    <!-- Command to perform no operation and maintain connection in FTP -->

    <field name="CommandCode" type="constant" length="4B" value="NOOP"/>
    <!-- Command code indicating no operation, used to keep the control connection alive -->

    <field name="EndOfLine" type="constant" length="2B" value="\r\n"/>
    <!-- Carriage Return and Line Feed indicating end of the command -->
</message>
</ir>

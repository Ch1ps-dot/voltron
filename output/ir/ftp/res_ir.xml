    <field name="ReplyText" type="variable" length="undefined" value="ASCII printable except CR, LF"/>
    <!-- Human-readable text describing additional information, typically includes estimated minutes server will be ready (e.g., "service ready in 5 minutes"). Content and length are implementation dependent but must exclude CR and LF characters. -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage return and line feed sequence indicating the end of the reply message -->
</message>

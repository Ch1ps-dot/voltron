  <message name="227">
    <!-- FTP server response to 'PASV' command; indicates entering passive mode and returns server IP and port for client data connection -->

    <field name="ReplyCode" type="constant" length="3B" value="227"/>
    <!-- FTP response code; signals "Entering Passive Mode" per RFC 959 -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Single space character between reply code and reply text -->

    <field name="ReplyTextPrefix" type="constant" length="29B" value="Entering Passive Mode ("/>
    <!-- Fixed text prefix that precedes the IP and port information; length may vary across implementations, but this is the canonical format per RFC 959 -->

    <field name="HostOctet1" type="variable" length="undefined" value="Decimal ASCII digits, 0-255"/>
    <!-- First octet of the server's IP address in decimal; actual digit count depends on value (e.g., '1' or '192') -->

    <field name="Comma1" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separator (,) between first and second IP octet -->

    <field name="HostOctet2" type="variable" length="undefined" value="Decimal ASCII digits, 0-255"/>
    <!-- Second octet of the server's IP address -->

    <field name="Comma2" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separator (,) between second and third IP octet -->

    <field name="HostOctet3" type="variable" length="undefined" value="Decimal ASCII digits, 0-255"/>
    <!-- Third octet of the server's IP address -->

    <field name="Comma3" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separator (,) between third and fourth IP octet -->

    <field name="HostOctet4" type="variable" length="undefined" value="Decimal ASCII digits, 0-255"/>
    <!-- Fourth octet of the server's IP address -->

    <field name="Comma4" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separator (,) between last IP octet and first port byte -->

    <field name="PortByte1" type="variable" length="undefined" value="Decimal ASCII digits, 0-255"/>
    <!-- First byte of the TCP port number (high byte); port = PortByte1*256 + PortByte2 -->

    <field name="Comma5" type="constant" length="1B" value="0x2C"/>
    <!-- Comma separator (,) between first and second port byte -->

    <field name="PortByte2" type="variable" length="undefined" value="Decimal ASCII digits, 0-255"/>
    <!-- Second byte of the TCP port number (low byte); port = PortByte1*256 + PortByte2 -->

    <field name="ReplyTextSuffix" type="constant" length="1B" value="0x29"/>
    <!-- Closing parenthesis ')' signaling end of the (h1,h2,h3,h4,p1,p2) tuple -->

    <field name="OptionalComment" type="variable" length="undefined" value="ASCII; any server-specific comment"/>
    <!-- Optional explanatory comment following the tuple, if present; may be empty -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed indicating end of FTP response message -->
</message>

<ir>
  <message name="110">
    <!-- FTP reply message with reply code 110: Restart marker reply. Indicates a marker reply to the user, used in response to a previous command requesting a marker. -->

    <field name="ReplyCode" type="constant" length="3B" value="110"/>
    <!-- 3-digit reply code indicating a Restart marker reply -->

    <field name="Whitespace" type="constant" length="1B" value="0x20"/>
    <!-- Space character separating reply code and the textual marker -->

    <field name="MarkerText" type="variable" length="undefined" value="ASCII excluding CR, LF"/>
    <!-- Textual marker information; exact syntax is implementation-dependent but generally contains identifier data. Ends before CRLF -->

    <field name="EndOfLine" type="constant" length="2B" value="0x0D0A"/>
    <!-- Carriage Return and Line Feed characters indicating end of the reply line -->
</message>
  <message name="120">
